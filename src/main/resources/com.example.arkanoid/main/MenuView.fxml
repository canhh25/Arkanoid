<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="640.0" prefWidth="960.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.arkanoid.controllers.MenuController">
   <children>
      <ImageView fitHeight="640.0" fitWidth="960.0" layoutX="380.0" layoutY="245.0" pickOnBounds="true"
                 preserveRatio="true" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                 AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <image>
            <Image url="@../../images/menu/menu.png" />
         </image>
      </ImageView>
      <Button fx:id="btnStart" layoutX="377.0" layoutY="253.0" mnemonicParsing="false" onAction="#handleStart"
              prefHeight="66.0" prefWidth="167.0" style="-fx-background-color: transparent;" />
      <Button fx:id="btnLevel" layoutX="377.0" layoutY="362.0" mnemonicParsing="false" onAction="#handleLevel"
              prefHeight="59.0" prefWidth="167.0" style="-fx-background-color: transparent;" />
      <Button fx:id="btnHelp" layoutX="377.0" layoutY="465.0" mnemonicParsing="false" onAction="#handleHelp"
              prefHeight="66.0" prefWidth="167.0" style="-fx-background-color: transparent;" />
      <Button fx:id="btnEsc" layoutX="14.0" layoutY="14.0" mnemonicParsing="false" onAction="#handleEsc" prefHeight="59.0"
              prefWidth="100.0" style="-fx-background-color: transparent;" />
      <ImageView fitHeight="66.0" fitWidth="129.0" layoutX="815.0" layoutY="11.0" onMouseClicked="#toggleVolume"
                 pickOnBounds="true" preserveRatio="true" AnchorPane.leftAnchor="815.0" AnchorPane.topAnchor="11.0">
         <image>
            <Image url="@../../images/menu/volume.png" />
         </image>
      </ImageView>
   </children>
</AnchorPane>
