<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="640.0" prefWidth="960.0" xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.arkanoid.controllers.LevelController">
   <children>
      <ImageView fitHeight="640.0" fitWidth="960.0" layoutX="200.0" layoutY="125.0"
                 pickOnBounds="true" preserveRatio="true" AnchorPane.bottomAnchor="0.0"
                 AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <image>
            <Image url="@../../images/menu/pause.png" />
         </image>
      </ImageView>
      <Button fx:id="btnResume" layoutX="370.0" layoutY="221.0" mnemonicParsing="false"
              onAction="#handleResume" prefHeight="67.0" prefWidth="172.0" style="-fx-background-color: transparent;" />
      <Button fx:id="btnRestart" layoutX="370.0" layoutY="320.0" mnemonicParsing="false"
              onAction="#handleRestart" prefHeight="67.0" prefWidth="172.0" style="-fx-background-color: transparent;" />
      <Button layoutX="370.0" layoutY="424.0" mnemonicParsing="false" onAction="#handleBack"
              prefHeight="67.0" prefWidth="172.0" style="-fx-background-color: transparent;" />
   </children>
</AnchorPane>
