<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="640.0" prefWidth="960.0" xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.arkanoid.controllers.MenuController">
      <ImageView fitHeight="640.0" fitWidth="960.0" layoutX="380.0" layoutY="245.0"
                 pickOnBounds="true" preserveRatio="true"
                 AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                 AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <Image url="@../../../../../resources/images/menu/menu.png" />
      </ImageView>
      <Button fx:id="btnStart" layoutX="364.0" layoutY="267.0" mnemonicParsing="false"
              onAction="#handleStart" prefHeight="60.0" prefWidth="233.0"
              style="-fx-background-color: transparent;" />
      <Button fx:id="btnHelp" layoutX="390.0" layoutY="367.0" mnemonicParsing="false"
              onAction="#handleHelp" prefHeight="60.0" prefWidth="181.0"
              style="-fx-background-color: transparent;" />
      <Button fx:id="btnEsc" layoutX="20.0" layoutY="14.0" mnemonicParsing="false"
              onAction="#handleEsc" prefHeight="50.0" prefWidth="84.0"
              style="-fx-background-color: transparent;" />
</AnchorPane>
